      <hashTree>
        <!-- JSR223 Sampler: Login with SSL bypass + token extraction (promotes to global property) -->
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="POST /api/auth/login (JSR223)" enabled="true">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">import javax.net.ssl.*;
import java.security.cert.X509Certificate;
import java.io.*;
import java.net.*;
import groovy.json.JsonSlurper;

// ── Trust all certs (self-signed) ──
TrustManager[] trustAll = [
    new X509TrustManager() {
        public X509Certificate[] getAcceptedIssuers() { return null; }
        public void checkClientTrusted(X509Certificate[] certs, String authType) { }
        public void checkServerTrusted(X509Certificate[] certs, String authType) { }
    }
] as TrustManager[];

SSLContext sc = SSLContext.getInstance("TLS");
sc.init(null, trustAll, new java.security.SecureRandom());
HttpsURLConnection.setDefaultSSLSocketFactory(sc.getSocketFactory());
HttpsURLConnection.setDefaultHostnameVerifier(new HostnameVerifier() {
    public boolean verify(String hostname, SSLSession session) { return true; }
});

// ── Send login request ──
URL url = new URL("https://localhost:3443/api/auth/login");
HttpsURLConnection conn = (HttpsURLConnection) url.openConnection();
conn.setRequestMethod("POST");
conn.setRequestProperty("Content-Type", "application/json");
conn.setDoOutput(true);

String body = '{"email":"admin@planex.com","password":"admin123"}';
OutputStream os = conn.getOutputStream();
os.write(body.getBytes("UTF-8"));
os.flush();
os.close();

int responseCode = conn.getResponseCode();
SampleResult.setResponseCode(String.valueOf(responseCode));
SampleResult.setResponseMessage(conn.getResponseMessage());

// ── Read response ──
BufferedReader br;
if (responseCode >= 400) {
    br = new BufferedReader(new InputStreamReader(conn.getErrorStream(), "UTF-8"));
} else {
    br = new BufferedReader(new InputStreamReader(conn.getInputStream(), "UTF-8"));
}
StringBuilder sb = new StringBuilder();
String line;
while ((line = br.readLine()) != null) {
    sb.append(line);
}
br.close();
String response = sb.toString();
SampleResult.setResponseData(response, "UTF-8");
SampleResult.setDataType(SampleResult.TEXT);

// ── Parse JSON and promote token to global property ──
if (responseCode == 200) {
    def json = new JsonSlurper().parseText(response);
    String token = json.accessToken;
    if (token) {
        props.put("auth.token", token);
        log.info("Auth token promoted to global property: " + (token.length() > 20 ? token.substring(0,20) + "..." : token));
        SampleResult.setSuccessful(true);
    } else {
        log.warn("No accessToken in login response: " + response);
        SampleResult.setSuccessful(false);
        SampleResult.setResponseCode("500");
        SampleResult.setResponseMessage("Token extraction failed");
    }
} else {
    log.warn("Login failed with code: " + responseCode + ", body: " + response);
    SampleResult.setSuccessful(false);
}</stringProp>
        </JSR223Sampler>
        <hashTree/>
      </hashTree>

      <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
