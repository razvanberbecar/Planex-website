          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Debug Response Body" enabled="true">
            <stringProp name="cacheKey"></stringProp>
            <stringProp name="script">// Log naive response body regardless of sampler success (assertions may fail independently)
String body = prev.getResponseDataAsString();
int maxLen = Math.min(300, body.length());
log.info("NAIVE DEBUG - Sample: " + prev.getSampleLabel() + " Code: " + prev.getResponseCode() + " Success: " + prev.isSuccessful());
log.info("NAIVE DEBUG - Body (" + maxLen + " chars): " + body.substring(0, maxLen));
// Also write to separate file for easier inspection
try {
  java.io.FileWriter fw = new java.io.FileWriter("naive_debug_body.txt", false);
  fw.write(body);
  fw.close();
  log.info("NAIVE DEBUG - Full body written to naive_debug_body.txt (" + body.length() + " bytes)");
} catch (Exception e) {
  log.error("NAIVE DEBUG - Failed to write file: " + e.getMessage());
}</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223PostProcessor>
