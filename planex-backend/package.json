{
  "name": "planex-backend",
  "version": "1.0.0",
  "description": "Planex REST API backend",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "vitest run --coverage",
    "ssl:generate": "node src/scripts/generate-ssl.js",
    "db:migrate": "npx sequelize-cli db:migrate",
    "db:migrate:undo": "npx sequelize-cli db:migrate:undo",
    "db:migrate:undo:all": "npx sequelize-cli db:migrate:undo:all",
    "db:seed": "npx sequelize-cli db:seed:all",
    "db:seed:undo": "npx sequelize-cli db:seed:undo:all",
    "db:faker": "node src/scripts/generate-faker-data.js",
    "ddos:simulate": "node src/scripts/ddos-simulation.js",
    "setup": "npm run ssl:generate && npx sequelize-cli db:migrate && npx sequelize-cli db:seed:all"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "@graphql-tools/schema": "^10.0.3",
    "@huggingface/inference": "^4.13.15",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.1",
    "express-validator": "^7.0.1",
    "graphql": "^16.8.1",
    "graphql-http": "^1.22.0",
    "jsonwebtoken": "^9.0.3",
    "magicast": "^0.3.5",
    "mongodb": "^7.2.0",
    "node-cache": "^5.1.2",
    "nodemailer": "^8.0.7",
    "pg": "^8.13.1",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.8",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  }
}
